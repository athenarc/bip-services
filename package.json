{
  "name": "bip-project",
  "version": "1.0.0",
  "description": "Yii2 project with code quality tools",
  "private": true,
  "scripts": {
    "lint:js": "eslint web/js/**/*.js --ext .js",
    "lint:js:fix": "eslint web/js/**/*.js --ext .js --fix",
    "lint:js:types": "tsc --noEmit",
    "lint:php": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "lint:php:fix": "vendor/bin/php-cs-fixer fix",
    "lint:phpcs": "vendor/bin/phpcs",
    "lint:phpstan": "vendor/bin/phpstan analyse",
    "lint:all": "npm run lint:js && npm run lint:js:types && npm run lint:php && npm run lint:phpcs && npm run lint:phpstan",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "web/js/**/*.js": [
      "eslint --fix"
    ],
    "*.php": [
      "vendor/bin/php-cs-fixer fix"
    ]
  }
}

